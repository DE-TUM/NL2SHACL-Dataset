# label: meta:FunctionShape
@prefix meta: <http://www.snik.eu/ontology/meta/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

meta:FunctionShape a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties meta:ignoredProperties,
        meta:topProperties ;
    sh:property [ sh:path meta:functionComponent ],
        [ sh:path meta:uses ],
        [ sh:path meta:updates ],
        [ sh:path meta:increases ],
        [ sh:path meta:decreases ],
        [ sh:hasValue meta:Function ;
            sh:path rdf:type ],
        meta:labelShape ;
    sh:targetClass meta:Function .

meta:labelShape a sh:PropertyShape ;
    sh:minCount 1 ;
    sh:path rdfs:label .