# label: meta:NotFunctionShape
@prefix meta: <http://www.snik.eu/ontology/meta/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

meta:NotFunctionShape a sh:NodeShape ;
    sh:not [ a sh:PropertyShape ;
            sh:hasValue meta:Function ;
            sh:path ( rdfs:subClassOf rdf:type ) ] ;
    sh:targetClass meta:EntityType,
        meta:Role .