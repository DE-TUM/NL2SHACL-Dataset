# label: meta:ApplicationComponentShape
@prefix meta: <http://www.snik.eu/ontology/meta/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

meta:ApplicationComponentShape a sh:NodeShape ;
    sh:property [ sh:path meta:communicatesWith ],
        [ sh:path meta:supports ],
        meta:labelShape ;
    sh:targetClass meta:ApplicationComponent .

meta:labelShape a sh:PropertyShape ;
    sh:minCount 1 ;
    sh:path rdfs:label .