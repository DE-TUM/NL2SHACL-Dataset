# label: meta:RoleShape
@prefix meta: <http://www.snik.eu/ontology/meta/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

meta:RoleShape a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties meta:ignoredProperties,
        meta:topProperties ;
    sh:property [ sh:path meta:isResponsibleForRole ],
        [ sh:path meta:roleComponent ],
        [ sh:path meta:isInvolvedIn ],
        [ sh:path meta:isResponsibleForFunction ],
        [ sh:path meta:isResponsibleForEntityType ],
        [ sh:path meta:approvesEntityType ],
        [ sh:path meta:approvesFunction ],
        [ sh:hasValue meta:Role ;
            sh:path rdf:type ],
        meta:labelShape ;
    sh:targetClass meta:Role .

meta:labelShape a sh:PropertyShape ;
    sh:minCount 1 ;
    sh:path rdfs:label .