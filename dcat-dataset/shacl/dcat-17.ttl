# label: foaf:Agent
@prefix : <http://data.europa.eu/r5r/mdrcv#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

foaf:Agent a sh:NodeShape ;
    sh:property [ sh:class skos:Concept ;
            sh:maxCount 1 ;
            sh:node :PublisherTypeRestriction ;
            sh:nodeKind sh:IRI ;
            sh:path dct:type ],
        [ sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:path foaf:name ;
            sh:severity sh:Violation ] .

:PublisherTypeRestriction a sh:NodeShape ;
    rdfs:label "Publisher type restriction" ;
    rdfs:comment "Publisher type restriction" ;
    owl:versionInfo "1" ;
    sh:property [ sh:class skos:ConceptScheme ;
            sh:hasValue <http://purl.org/adms/publishertype/1.0> ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path skos:inScheme ] .