# label: dcat:Distribution
@prefix : <http://data.europa.eu/r5r/mdrcv#> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcat:Distribution a sh:NodeShape ;
    sh:property [ sh:class skos:Concept ;
            sh:node :FileTypeRestriction ;
            sh:nodeKind sh:IRI ;
            sh:path dct:format ],
        [ sh:class skos:Concept ;
            sh:node :StatusRestriction ;
            sh:nodeKind sh:IRI ;
            sh:path adms:status ] .

:FileTypeRestriction a sh:NodeShape ;
    rdfs:label "File Type Restriction" ;
    rdfs:comment "File Type Restriction" ;
    rdfs:subClassOf rdfs:Resource ;
    owl:versionInfo "1" ;
    sh:property [ sh:class skos:ConceptScheme ;
            sh:hasValue <http://publications.europa.eu/resource/authority/file-type> ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path skos:inScheme ] .

:StatusRestriction a sh:NodeShape ;
    rdfs:label "Status restriction" ;
    rdfs:comment "Status restriction" ;
    owl:versionInfo "1" ;
    sh:property [ sh:class skos:ConceptScheme ;
            sh:hasValue <http://purl.org/adms/status/1.0> ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path skos:inScheme ] .