# label: dcat:Catalog-1
@prefix : <http://data.europa.eu/r5r#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:DateOrDateTimeDataType a sh:NodeShape ;
    rdfs:label "Date time date disjunction" ;
    rdfs:comment "Date time date disjunction shape checks that a datatype property receives a date or a dateTime literal" ;
    sh:message "The values must be data typed as either xsd:date or xsd:dateTime" ;
    sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:dateTime ] ) .

dcat:Catalog a sh:NodeShape ;
    sh:targetClass dcat:Catalog ;
    sh:name "Catalog"@en ;
    sh:property [ sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:path dct:description ;
            sh:severity sh:Violation ],
        [ sh:class dcat:Catalog ;
            sh:path dct:hasPart ;
            sh:severity sh:Violation ],
        [ sh:class dcat:Catalog ;
            sh:maxCount 1 ;
            sh:path dct:isPartOf ;
            sh:severity sh:Violation ],
        [ sh:maxCount 1 ;
            sh:node :DateOrDateTimeDataType ;
            sh:path dct:issued ;
            sh:severity sh:Violation ],
        [ sh:nodeKind sh:IRI ;
            sh:path dct:language ],
        [ sh:class dct:LicenseDocument ;
            sh:maxCount 1 ;
            sh:path dct:license ;
            sh:severity sh:Violation ],
        [ sh:maxCount 1 ;
            sh:node :DateOrDateTimeDataType ;
            sh:path dct:modified ;
            sh:severity sh:Violation ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path dct:publisher ],
        [ sh:class dct:RightsStatement ;
            sh:maxCount 1 ;
            sh:path dct:rights ;
            sh:severity sh:Violation ],
        [ sh:nodeKind sh:IRI ;
            sh:path dct:spatial ;
            sh:severity sh:Violation ],
        [ sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:path dct:title ;
            sh:severity sh:Violation ],
        [ sh:class dcat:Dataset ;
            sh:minCount 1 ;
            sh:path dcat:dataset ;
            sh:severity sh:Violation ],
        [ sh:class dcat:CatalogRecord ;
            sh:path dcat:record ;
            sh:severity sh:Violation ],
        [ sh:nodeKind sh:IRI ;
            sh:path dcat:themeTaxonomy ;
            sh:severity sh:Violation ],
        [ sh:class foaf:Document ;
            sh:maxCount 1 ;
            sh:path foaf:homepage ;
            sh:severity sh:Violation ] .