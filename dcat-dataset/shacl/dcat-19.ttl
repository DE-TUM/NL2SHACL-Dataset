# label: dcat:Distribution-1
@prefix : <http://data.europa.eu/r5r#> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix spdx: <http://spdx.org/rdf/terms#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcat:Distribution a sh:NodeShape ;
    sh:property [ sh:nodeKind sh:BlankNodeOrIRI ;
            sh:path dct:conformsTo ;
            sh:severity sh:Violation ],
        [ sh:nodeKind sh:Literal ;
            sh:path dct:description ;
            sh:severity sh:Violation ],
        [ sh:class dct:MediaTypeOrExtent ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path dct:format ;
            sh:severity sh:Violation ],
        [ sh:maxCount 1 ;
            sh:node :DateOrDateTimeDataType ;
            sh:path dct:issued ;
            sh:severity sh:Violation ],
        [ sh:class dct:LinguisticSystem ;
            sh:path dct:language ;
            sh:severity sh:Violation ],
        [ sh:class dct:LicenseDocument ;
            sh:maxCount 1 ;
            sh:path dct:license ;
            sh:severity sh:Violation ],
        [ sh:maxCount 1 ;
            sh:node :DateOrDateTimeDataType ;
            sh:path dct:modified ;
            sh:severity sh:Violation ],
        [ sh:class dct:RightsStatement ;
            sh:maxCount 1 ;
            sh:path dct:rights ;
            sh:severity sh:Violation ],
        [ sh:nodeKind sh:Literal ;
            sh:path dct:title ;
            sh:severity sh:Violation ],
        [ sh:class spdx:Checksum ;
            sh:maxCount 1 ;
            sh:path spdx:checksum ;
            sh:severity sh:Violation ],
        [ sh:class skos:Concept ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path adms:status ;
            sh:severity sh:Violation ],
        [ sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path dcat:accessURL ;
            sh:severity sh:Violation ],
        [ sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:path dcat:byteSize ;
            sh:severity sh:Violation ],
        [ sh:nodeKind sh:IRI ;
            sh:path dcat:downloadURL ;
            sh:severity sh:Violation ],
        [ sh:class dct:MediaTypeOrExtent ;
            sh:maxCount 1 ;
            sh:path dcat:mediaType ;
            sh:severity sh:Violation ],
        [ sh:class foaf:Document ;
            sh:path foaf:page ;
            sh:severity sh:Violation ] .

:DateOrDateTimeDataType a sh:NodeShape ;
    rdfs:label "Date time date disjunction" ;
    rdfs:comment "Date time date disjunction shape checks that a datatype property receives a date or a dateTime literal" ;
    sh:message "The values must be data typed as either xsd:date or xsd:dateTime" ;
    sh:or ( [ sh:datatype xsd:date ] [ sh:datatype xsd:dateTime ] ) .