# label: epo-shape:epo-DirectContractShape
@prefix epo: <http://data.europa.eu/a4g/ontology#> .
@prefix epo-shape: <http://data.europa.eu/a4g/data-shape#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

epo-shape:epo-DirectContractShape a sh:NodeShape ;
    rdfs:label "Direct Contract" ;
    rdfs:comment "A Contract resulting from Lot Award Outcome. Additional information: A Framework Agreement is not a Direct Contract." ;
    rdfs:isDefinedBy epo-shape:core-shape ;
    sh:property epo-shape:epo-DirectContract-epo-resultsFromLotAwardOutcome ;
    sh:targetClass epo:DirectContract .

epo-shape:epo-DirectContract-epo-resultsFromLotAwardOutcome a sh:PropertyShape ;
    rdfs:isDefinedBy epo-shape:core-shape ;
    sh:class epo:LotAwardOutcome ;
    sh:description "Relation to indicate that a given type of Contract is a consequence of a given Lot Award Outcome." ;
    sh:name "Results from lot award outcome" ;
    sh:nodeKind sh:IRI ;
    sh:path epo:resultsFromLotAwardOutcome .