# label: epo-shape:epo-ord-ContractInformationShape
@prefix epo: <http://data.europa.eu/a4g/ontology#> .
@prefix epo-shape: <http://data.europa.eu/a4g/data-shape#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

epo-shape:epo-ord-ContractInformationShape a sh:NodeShape ;
    rdfs:label "Contract Information" ;
    rdfs:comment "Information about the Contract." ;
    rdfs:isDefinedBy epo-shape:ord-shape ;
    sh:property epo-shape:epo-ord-ContractInformation-epo-ord-concernsContract,
        epo-shape:epo-ord-ContractInformation-epo-ord-isSpecificToOrderLine ;
    sh:targetClass epo:ContractInformation .

epo-shape:epo-ord-ContractInformation-epo-ord-concernsContract a sh:PropertyShape ;
    rdfs:isDefinedBy epo-shape:ord-shape ;
    sh:class epo:Contract ;
    sh:description "Relates to Contractor." ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Concerns contract" ;
    sh:nodeKind sh:IRI ;
    sh:path epo:concernsContract .

epo-shape:epo-ord-ContractInformation-epo-ord-isSpecificToOrderLine a sh:PropertyShape ;
    rdfs:isDefinedBy epo-shape:ord-shape ;
    sh:class epo:OrderLine ;
    sh:description "Information that is particular to one or multiple Order Lines." ;
    sh:name "Is specific to order line" ;
    sh:nodeKind sh:IRI ;
    sh:path epo:isSpecificToOrderLine .