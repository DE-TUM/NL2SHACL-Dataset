# label: PersonGenderShape
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ex: <http://example.org/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

ex:PersonGenderShape
    a sh:NodeShape ;
    sh:description "The gender of a person can only be 'Male', 'Female', or 'Other'."@en ;
    sh:targetClass dbo:Person ;
    sh:property [
        sh:path dbo:gender ;
        sh:in ("Male" "Female" "Other") ;
        sh:message "Gender must be 'Male', 'Female', or 'Other'."@en ;
    ] .