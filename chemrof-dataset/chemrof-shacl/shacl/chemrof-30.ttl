# label: chemrof:FullyCovalentlyBonded
@prefix chemrof: <https://w3id.org/chemrof/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

chemrof:FullyCovalentlyBonded a sh:NodeShape ;
    sh:closed false ;
    sh:description "All pairs of atoms in this entity are transitively connected via covalent bonds" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:name "fully covalently bonded" ;
    sh:targetClass chemrof:FullyCovalentlyBonded .