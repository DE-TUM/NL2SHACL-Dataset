# label: chemrof:EntityWithIsotopeSpecified
@prefix chemrof: <https://w3id.org/chemrof/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

chemrof:EntityWithIsotopeSpecified a sh:NodeShape ;
    sh:closed false ;
    sh:description "A mixin for an entity where the charge is explicitly specified (corresponding to the /q layer in InChI)" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:name "entity with isotope specified" ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:name "inchi isotopic layer" ;
            sh:order 0 ;
            sh:path chemrof:inchi_isotopic_layer ;
            sh:pattern "^[ih].*" ] ;
    sh:targetClass chemrof:EntityWithIsotopeSpecified .