# label: chemrof:Collection
@prefix chemrof: <https://w3id.org/chemrof/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

chemrof:Collection a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class chemrof:DomainEntity ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path chemrof:entities ] ;
    sh:targetClass chemrof:Collection .