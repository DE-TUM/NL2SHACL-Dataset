# label: chemrof:ChiralityCenter
@prefix chemrof: <https://w3id.org/chemrof/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

chemrof:ChiralityCenter a sh:NodeShape ;
    sh:closed true ;
    sh:description "a stereocenter consisting of an atom holding a set of ligands (atoms or groups of atoms) in a spatial arrangement which is not superimposable on its mirror image. " ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:name "chirality center" ;
    sh:targetClass chemrof:ChiralityCenter .