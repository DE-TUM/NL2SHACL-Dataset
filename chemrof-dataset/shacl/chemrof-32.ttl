# label: chemrof:GeneralAcidBaseGroupingClass
@prefix chemrof: <https://w3id.org/chemrof/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

chemrof:GeneralAcidBaseGroupingClass a sh:NodeShape ;
    sh:closed true ;
    sh:description "A molecule grouping class that can groups an acid together with all its conjugate bases. physiological" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:name "general acid base grouping class" ;
    sh:property [ sh:class chemrof:ChemicalEntity ;
            sh:maxCount 1 ;
            sh:name "conjugate acid of" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path chemrof:conjugate_acid_of ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "id" ;
            sh:order 2 ;
            sh:path chemrof:id ],
        [ sh:class owl:Class ;
            sh:description "Holds between C and P if C owl:subClassOf P. Note that in this model, most classes are metaclasses (see 'owl class'), where these metaclasses may represent *groupings* or specific countable elements or species. We provide two different sub-properties of subclass of for two cases: (1) subtype_of, which connects grouping classes (e.g. alkane is_a hydrocarbon; alpha-amino-acid is_a amino-acid), (2) classified_by, which connects a specific element to a grouping class (e.g. methane is_a hydrocarbon; iron is_a metal; serine is_a amino-acid)" ;
            sh:maxCount 1 ;
            sh:name "owl subclass of" ;
            sh:nodeKind sh:BlankNode ;
            sh:order 3 ;
            sh:path chemrof:owl_subclass_of ],
        [ sh:class chemrof:ChemicalEntity ;
            sh:description "connects the base form of an acid to an acid. Also connects the different charge states of the base. Example: the different charge states of lactate (CHEBI:24996) conjugate base of lactic acid (CHEBI:28358)" ;
            sh:maxCount 1 ;
            sh:name "conjugate base of" ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path chemrof:conjugate_base_of ],
        [ sh:datatype xsd:string ;
            sh:description "name of chemical entity. E.g. nickel, carbon-16" ;
            sh:maxCount 1 ;
            sh:name "name" ;
            sh:order 4 ;
            sh:path rdfs:label ],
        [ sh:class chemrof:MoleculeGroupingClass ;
            sh:description "grouping classes can be arranged in hierarchies arbitrarily deep. Note that subtype_of should only connect two grouping classes" ;
            sh:name "subtype of" ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path chemrof:subtype_of ] ;
    sh:targetClass chemrof:GeneralAcidBaseGroupingClass .